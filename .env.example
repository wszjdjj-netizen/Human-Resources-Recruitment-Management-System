# Docker Compose production example
# Copy this file to .env in the project root before running docker compose.

POSTGRES_PASSWORD=replace-with-a-strong-database-password
ENVIRONMENT=production
SECRET_KEY=replace-with-a-random-secret-key
CREDENTIAL_ENCRYPTION_KEY=replace-with-another-random-secret-key
ALLOW_PUBLIC_REGISTRATION=false
REGISTRATION_INVITE_CODE=
SECURE_COOKIES=true
COOKIE_SAMESITE=lax
ALLOW_PRIVATE_NETWORK_URLS=false
RUNNER_TOKEN_TTL_MINUTES=30
MAX_RUNNER_SCREENSHOT_SIZE_MB=5

AI_ENDPOINT=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
ALLOW_AI_ENV_FALLBACK=false

# Use your real frontend domain(s), separated by commas.
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Public backend URL used by each user's local sourcing runner.
# If frontend and backend share one domain through nginx /api proxy,
# this can be https://yourdomain.com.
PUBLIC_BACKEND_URL=https://yourdomain.com
