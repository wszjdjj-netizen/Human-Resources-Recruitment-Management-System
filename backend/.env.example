# 数据库配置
# 开发环境使用SQLite，生产环境请改为PostgreSQL
ENVIRONMENT=development
DATABASE_URL=sqlite:///./recruitment.db
# 生产环境示例: DATABASE_URL=postgresql://user:password@localhost:5432/recruitment

# JWT密钥（生产环境必须更换为强随机字符串！）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
# 生产环境必须设置，并保持长期稳定；它用于加密用户AI Key和平台凭据。
CREDENTIAL_ENCRYPTION_KEY=replace-with-another-random-secret-key
JWT_EXPIRE_DAYS=7

# 注册控制
# 生产环境建议设置邀请码，或关闭公开注册后由管理员创建账号。
ALLOW_PUBLIC_REGISTRATION=false
REGISTRATION_INVITE_CODE=
SECURE_COOKIES=false
COOKIE_SAMESITE=lax
ALLOW_PRIVATE_NETWORK_URLS=false
RUNNER_TOKEN_TTL_MINUTES=30
MAX_RUNNER_SCREENSHOT_SIZE_MB=5

# 默认AI接口配置（仅作为兼容兜底；正常情况下每个用户在前端「AI配置」中自行保存）
AI_ENDPOINT=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
ALLOW_AI_ENV_FALLBACK=false

# CORS配置（生产环境请配置实际域名，多个域名用逗号分隔）
# 示例: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 公网后端地址（平台搜人的本地执行器会用它回传任务结果）
# 示例: PUBLIC_BACKEND_URL=https://api.yourdomain.com
PUBLIC_BACKEND_URL=

# 文件上传配置
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# ===========================================
# 部署说明
# ===========================================
# 1. 复制此文件为 .env
# 2. 修改 SECRET_KEY 为随机字符串
# 3. 生产环境改用 PostgreSQL 数据库
# 4. 配置 CORS_ORIGINS 为实际域名
# 5. 设置 REGISTRATION_INVITE_CODE，避免公网被随意注册刷AI费用
# 6. 本地 http 开发使用 SECURE_COOKIES=false；线上 https 使用 true
# 7. 用户登录后在「AI配置」页面保存自己的 API Key
# ===========================================
